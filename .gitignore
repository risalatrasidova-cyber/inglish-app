# Monorepo root — ignore local/generated files everywhere

# Dependencies
node_modules/

# Builds & TypeScript emit
dist/
build/
*.tsbuildinfo

# Secrets & local env (keep **/.env.example in repo)
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Local databases (SQLite / dev)
*.db
*.sqlite
*.sqlite3

# User uploads & generated media (admin uploads)
backend/uploads/
uploads/

# Logs & debug
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Tests / coverage
coverage/
.nyc_output/

# OS
.DS_Store
Thumbs.db

# Editors & Cursor
.idea/
*.swp
*.swo
*~
.cursor/

# Vite (frontend)
.vite/

# Optional package manager caches
.pnpm-store/
.yarn/cache/
