# База данных
# Вариант 1: SQLite (без установки PostgreSQL)
DB_TYPE=sqlite
DB_DATABASE=./inglish_app.db

# Вариант 2: PostgreSQL
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_DATABASE=inglish_app

# JWT
# JWT_SECRET=your-secret-key
# JWT_EXPIRES_IN=7d

# Фронтенд (CORS)
# FRONTEND_URL=http://localhost:5173
