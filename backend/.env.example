# База данных
# Вариант 1: SQLite (без установки PostgreSQL)
DB_TYPE=sqlite
DB_DATABASE=./inglish_app.db

# Вариант 2: PostgreSQL (локально) — не задавайте DATABASE_URL одновременно с этим блоком для приложения
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_DATABASE=inglish_app

# Вариант 3: Render / облако — одна переменная (сервис сам подставляет при линке Postgres)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# JWT
# JWT_SECRET=your-secret-key
# JWT_EXPIRES_IN=7d

# Фронтенд (CORS) — должен совпадать с origin в браузере (схема + хост, без пути)
# Одна строка:
# FRONTEND_URL=http://localhost:5173
# Несколько origin через запятую (Render + Vercel preview + prod):
# FRONTEND_URL=http://localhost:5173,https://your-app.vercel.app,https://your-app-git-branch-user.vercel.app
# После деплоя в логах Render будет строка: CORS allowed origins (N): ...
#
# Миграции БД при старте приложения (пустая Postgres на Render). Отключить: SKIP_DB_MIGRATIONS_ON_BOOT=1
# SKIP_DB_MIGRATIONS_ON_BOOT=1
